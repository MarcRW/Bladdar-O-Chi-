<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>T4M-4.GOT-C · Bladdar-O-Chi</title>
<style>
  html,body{margin:0;padding:0;height:100%;background:#0a0d18;overflow:hidden;
    font-family:"Courier New",monospace;-webkit-user-select:none;user-select:none;}
  /* starfield */
  .st{position:fixed;border-radius:50%;background:#cfe0ff;pointer-events:none;
    animation:tw 6s ease-in-out infinite;}
  @keyframes tw{0%,100%{opacity:.15}50%{opacity:.8}}
  #wrap{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;}
  /* egg chassis */
  #egg{position:relative;width:340px;max-width:92vw;padding:34px 26px 30px;
    background:radial-gradient(ellipse at 32% 22%, #3a3f4c 0%, #23262f 45%, #14161d 100%);
    border-radius:48% 48% 46% 46% / 56% 56% 44% 44%;
    box-shadow:0 22px 60px rgba(0,0,0,.75), inset 0 2px 3px rgba(255,255,255,.10),
      inset 0 -14px 30px rgba(0,0,0,.55);}
  #crest{display:block;margin:0 auto 12px;opacity:.5;}
  #bezel{background:#0c0e12;border-radius:14px;padding:12px;
    box-shadow:inset 0 3px 8px rgba(0,0,0,.9), 0 1px 0 rgba(255,255,255,.06);}
  #lcd{display:block;width:100%;image-rendering:pixelated;border-radius:4px;
    background:#a9bf62;box-shadow:inset 0 0 18px rgba(40,55,10,.35);}
  #plate{margin:12px auto 14px;width:78%;text-align:center;background:#d8d8d2;
    color:#1c1e24;font-weight:bold;font-size:15px;letter-spacing:2px;
    padding:4px 0;border-radius:5px;box-shadow:inset 0 -2px 3px rgba(0,0,0,.25);}
  #btns{display:flex;align-items:center;justify-content:center;gap:26px;}
  .btn{background:radial-gradient(ellipse at 35% 30%, #3d424e, #171a21 70%);
    border:none;border-radius:50%;cursor:pointer;
    box-shadow:0 4px 8px rgba(0,0,0,.7), inset 0 1px 2px rgba(255,255,255,.14);}
  .btn:active{transform:translateY(2px);box-shadow:0 2px 4px rgba(0,0,0,.7);}
  #bA,#bC{width:44px;height:34px;border-radius:46%;}
  #bB{width:58px;height:44px;}
  .lbl{color:#7d8494;font-size:10px;text-align:center;margin-top:5px;letter-spacing:1px;}
  #led{width:7px;height:7px;border-radius:50%;background:#5a3208;align-self:center;
    box-shadow:0 0 4px #000 inset;}
  #led.on{background:#ff9d2e;box-shadow:0 0 8px #ff9d2e;}
  .col{display:flex;flex-direction:column;align-items:center;}
</style>
</head>
<body>
<div id="wrap">
  <div id="egg">
    <svg id="crest" width="64" height="40" viewBox="0 0 64 40">
      <g fill="none" stroke="#8a8f9c" stroke-width="2.2" stroke-linecap="round">
        <path d="M10 12 Q4 4 14 6 Q20 7 24 14"/><path d="M54 12 Q60 4 50 6 Q44 7 40 14"/>
        <circle cx="24" cy="20" r="7"/><circle cx="40" cy="20" r="7"/>
        <circle cx="24" cy="20" r="2.4" fill="#8a8f9c"/><circle cx="40" cy="20" r="2.4" fill="#8a8f9c"/>
        <path d="M30 24 L32 28 L34 24"/>
      </g>
    </svg>
    <div id="bezel"><canvas id="lcd" width="128" height="96"></canvas></div>
    <div id="plate">T4M-4.GOT-C</div>
    <div id="btns">
      <div class="col"><button class="btn" id="bA" aria-label="pandebono"></button><div class="lbl">PAN</div></div>
      <div id="led"></div>
      <div class="col"><button class="btn" id="bB" aria-label="cariño"></button><div class="lbl">MIMO</div></div>
      <div class="col"><button class="btn" id="bC" aria-label="siesta"></button><div class="lbl">LUZ</div></div>
    </div>
  </div>
</div>
<script>
(function(){
"use strict";
/* ---------- starfield ---------- */
for(var i=0;i<60;i++){var s=document.createElement('div');s.className='st';
  var z=Math.random()<.15?2.6:1.4;
  s.style.cssText+='width:'+z+'px;height:'+z+'px;left:'+(Math.random()*100)+'%;top:'
  +(Math.random()*100)+'%;animation-duration:'+(4+Math.random()*7)+'s;animation-delay:'
  +(Math.random()*6)+'s;';document.body.appendChild(s);}

/* ---------- LCD ---------- */
var cv=document.getElementById('lcd'),cx=cv.getContext('2d');
var W=128,H=96,PIX=1;
var COL={bg:'#a9bf62',dk:'#253216',md:'#4f6a30',lt:'#dcea9c'};
function cls(){cx.fillStyle=COL.bg;cx.fillRect(0,0,W,H);
  cx.globalAlpha=.06;cx.fillStyle='#253216';
  for(var y=0;y<H;y+=2){cx.fillRect(0,y,W,1);}cx.globalAlpha=1;}
function px(x,y,c){cx.fillStyle=COL[c];cx.fillRect(x|0,y|0,1,1);}
function sprite(art,ox,oy,flip){
  for(var r=0;r<art.length;r++){var row=art[r];
    for(var c=0;c<row.length;c++){var ch=row[c];if(ch==='.')continue;
      var col=ch==='#'?'dk':(ch==='+'?'md':'lt');
      var xx=flip?ox+(row.length-1-c):ox+c;px(xx,oy+r,col);}}}
function text(str,x,y){cx.fillStyle=COL.dk;cx.font='7px monospace';
  cx.textBaseline='top';cx.fillText(str,x,y);}

/* ---------- sprites ---------- */
var BLOB1=[ // fluffy idle
"....######....",
"..##++++++##..",
".#+++#++#+++#.",
"#+++o##o##+++#",
"#++#o.##.o#++#",
"#+++######+++#",
"#++++#..#++++#",
"#+++++##+++++#",
".#++++++++++#.",
".#+#++++++#+#.",
"..#..####..#..",
"...##....##..."];
var BLOB2=[
"....######....",
"..##++++++##..",
".#+++#++#+++#.",
"#+++####+++++#",
"#++#....#++++#",
"#+++######+++#",
"#++++#..#++++#",
"#+++++##+++++#",
".#++++++++++#.",
".#+#++++++#+#.",
"..#..####..#..",
"...##....##..."];
var MAD1=[
"..#..######..#",
".##.##++++##..",
".#+#+#++#+#+#.",
"#++#o##o##+++#",
"#++o.##.o.#++#",
"#+++######+++#",
"#+++######+++#",
"#++#oo##oo#++#",
".#+#oooooo#+#.",
".#+##oooo##+#.",
"..#...##...#..",
"..##..##..##.."];
var RUN1=[
"..############",
".##++++++++##.",
"#++o##oo##o++#",
"#++.##..##.++#",
"#++########++#",
"#++##oooo##++#",
".#++######++#.",
"..#++++++++#..",
"...##.##.##...",
"..##...##....."];
var RUN2=[
"..############",
".##++++++++##.",
"#++o##oo##o++#",
"#++.##..##.++#",
"#++########++#",
"#++##oooo##++#",
".#++######++#.",
"..#++++++++#..",
"....##.##.....",
".....##..##..."];
var STONE=[".oo.","o++o","#++#",".##."];
var PAN=[".ooo.","o+++o","o+++o",".ooo."]; // pandebono
var CACTI=[ // 6 stages
 [],
 ["..#..","..#..",".###."],
 ["..#..",".+#..","..#+.","..#..",".###."],
 ["..#..","#.+#.","##.#+","..##.","..#..",".###."],
 ["..#..","#.+#.#","##.#+#","..###.","..##..","..#...",".####."],
 ["..o#o.","#.+#.#","##.#+#","o.###.","..##..","..#...",".####."]];
/* wall rows built from stones */

/* ---------- state ---------- */
var KEY='bladdarochi_v1';
var st={born:Date.now(),seen:Date.now(),hun:20,att:80,wall:0,streak:0,
        cact:0,prog:0,nap:false,care:0,bloomSeen:false};
try{var raw=localStorage.getItem(KEY);if(raw){var o=JSON.parse(raw);
  for(var k in st){if(o[k]!==undefined)st[k]=o[k];}}}catch(e){}
function save(){st.seen=Date.now();try{localStorage.setItem(KEY,JSON.stringify(st));}catch(e){}}

/* away-time reckoning */
var awayMsg=null;
(function(){var hrs=(Date.now()-st.seen)/36e5;if(hrs<0)hrs=0;
  if(hrs>0.02){
    var f=st.nap?0.5:1;
    st.hun=Math.min(100,st.hun+hrs*4*f);
    st.att=Math.max(0,st.att-hrs*5*f);
    if(hrs>=8&&(st.hun>70||st.att<30)){
      st.streak=Math.min(6,st.streak+1);
      st.wall=Math.min(5,st.streak);
      awayMsg=st.wall>=5?'MURO TERMINADO.':'CONSTRUYO UN MURO';
    }else if(hrs>=8){awayMsg='TE ESPERO...';}
  }})();

/* ---------- audio ---------- */
var AC=null;function beep(f,d){try{AC=AC||new (window.AudioContext||window.webkitAudioContext)();
  var o=AC.createOscillator(),g=AC.createGain();o.type='square';o.frequency.value=f;
  g.gain.value=.03;o.connect(g);g.connect(AC.destination);o.start();
  o.stop(AC.currentTime+(d||.08));}catch(e){}}

/* ---------- game logic ---------- */
var msg=awayMsg||'BLADDAR-O-CHI',msgT=Date.now()+4000,frame=0,eatT=0,petCd=0;
function mood(){
  if(st.nap)return 'nap';
  if(eatT>0)return 'eat';
  if(st.att<15&&st.hun>80)return 'rampage';
  if(st.att<25)return 'tantrum';
  if(st.att<45||st.hun>65)return 'forager';
  return 'happy';}
function say(m,ms){msg=m;msgT=Date.now()+(ms||2500);}

document.getElementById('bA').addEventListener('click',function(){
  if(st.nap){say('SHHH... DUERME');return;}
  beep(660,.09);setTimeout(function(){beep(880,.1);},100);
  st.hun=Math.max(0,st.hun-60);st.att=Math.min(100,st.att+15);
  eatT=6;st.streak=0;say('ÑAM ÑAM PANDEBONO');save();});
document.getElementById('bB').addEventListener('click',function(){
  if(st.nap){say('ZZZ...');return;}
  if(Date.now()<petCd){return;}petCd=Date.now()+8000;
  beep(520,.07);st.att=Math.min(100,st.att+12);st.streak=0;say('PRRR...FLUFF');save();});
document.getElementById('bC').addEventListener('click',function(){
  st.nap=!st.nap;beep(st.nap?300:440,.1);
  say(st.nap?'LUZ APAGADA':'BUENOS DIAS');
  document.getElementById('led').classList.toggle('on',st.nap);save();});
cv.addEventListener('click',function(){if(!st.nap){st.att=Math.min(100,st.att+3);beep(700,.04);}});
/* crest ritual: 5 taps cycles moods (debug/science) */
var crestTaps=0,crestT=0,moodCycle=0;
document.getElementById('crest').addEventListener('click',function(){
  var now=Date.now();if(now-crestT>2500)crestTaps=0;crestT=now;crestTaps++;
  if(crestTaps>=5){crestTaps=0;moodCycle=(moodCycle%4)+1;beep(900,.05);
    if(moodCycle===1){st.hun=20;st.att=80;st.wall=0;say('MODO: FELIZ');}
    else if(moodCycle===2){st.hun=70;st.att=40;say('MODO: RECOLECTOR');}
    else if(moodCycle===3){st.hun=75;st.att=20;say('MODO: BERRINCHE');}
    else{st.hun=90;st.att=10;st.wall=3;say('MODO: ¡MAYHEM!');}
    save();}});

/* per-second tick */
setInterval(function(){
  frame++;
  if(eatT>0)eatT--;
  var f=st.nap?0.35:1;
  st.hun=Math.min(100,st.hun+(4/3600)*f);   /* ~4/h */
  st.att=Math.max(0,st.att-(5/3600)*f);     /* ~5/h */
  /* care economy: good minutes dissolve wall then grow cactus */
  if(!st.nap&&mood()==='happy'){st.care++;
    if(st.care>=60){st.care=0;
      if(st.wall>0){st.wall--;say('DEVUELVE UNA PIEDRA');}
      else if(st.cact<5){st.prog++;if(st.prog>=4){st.prog=0;st.cact++;
        say(st.cact>=5?'¡FLOR! 🌵':'EL CACTUS CRECE');
        if(st.cact>=5&&!st.bloomSeen){st.bloomSeen=true;beep(880,.1);
          setTimeout(function(){beep(1100,.12);},130);}}}}}
  if(frame%20===0)save();
  render();
},1000);

/* ---------- render ---------- */
function drawWall(){
  if(st.wall<=0)return;
  var rows=st.wall; /* 1..5 rows of fitted stones */
  for(var r=0;r<rows;r++){var y=H-14-r*4;
    var off=(r%2)*3;
    for(var x=off;x<W-6;x+=6){sprite(STONE,x,y,false);}}
  if(st.wall>=5){text('SACSAYHUAMAN',30,H-40);}}
function drawCactus(){
  var c=CACTI[st.cact];if(!c.length)return;
  sprite(c,108,H-16-c.length,false);}
function drawStones(n,ox,oy){for(var i=0;i<n;i++){
  sprite(STONE,ox+(i%3)*6,oy-((i/3)|0)*4,false);}}
function render(){
  cls();
  var m=mood(),f2=frame%2===0,bob=f2?0:1;
  if(m==='nap'){
    sprite(BLOB2,54,60);text('z',76,46+bob);text('Z',82,38-bob);
    cx.globalAlpha=.25;cx.fillStyle='#253216';cx.fillRect(0,0,W,H);cx.globalAlpha=1;
  }else if(m==='eat'){
    sprite(f2?BLOB1:BLOB2,54,58);sprite(PAN,72,66);text('*',66,54);
  }else if(m==='rampage'){
    /* corridor scroll */
    var off=(frame*6)%24;
    for(var x=-off;x<W;x+=24){cx.fillStyle=COL.md;cx.fillRect(x,20,2,60);
      cx.fillRect(x+10,26,6,6);} /* pipes+portholes */
    cx.fillStyle=COL.dk;cx.fillRect(0,80,W,2);
    sprite(f2?RUN1:RUN2,50,64,true);
    if(frame%3===0)sprite(STONE,30+(frame*7)%60,40+(frame*5)%20,false);
    text('¡¡MAYHEM!!',6,32);
  }else if(m==='tantrum'){
    sprite(MAD1,54,56+bob);
    sprite(STONE,30+(frame*9)%30,44+((frame*4)%16),false);
    sprite(STONE,84-(frame*7)%26,50+((frame*3)%12),false);
    text('¡GRRR!',52,40);
  }else if(m==='forager'){
    sprite(f2?BLOB1:BLOB2,44,58);
    drawStones(3+(st.hun>75?3:0),80,H-20);
    text('...',66,50);
  }else{
    sprite(f2?BLOB1:BLOB2,50,58+bob);
    drawCactus();
  }
  drawWall();
  /* status bars */
  cx.fillStyle=COL.dk;cx.fillRect(4,4,40,4);cx.fillRect(4,11,40,4);
  cx.fillStyle=COL.lt;
  cx.fillRect(5,5,38*(1-st.hun/100),2);
  cx.fillRect(5,12,38*(st.att/100),2);
  text('PAN',46,2);text('AMOR',46,9);
  /* message line */
  if(Date.now()<msgT){text(msg,4,H-9);}
}
render();
})();
</script>
</body>
</html>
